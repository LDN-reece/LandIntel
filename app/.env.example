SUPABASE_DB_URL=postgresql+psycopg://postgres:password@db.project-ref.supabase.co:5432/postgres
SUPABASE_URL=https://project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

GEONETWORK_BASE_URL=https://spatialdata.gov.scot/geonetwork
BOUNDARY_PACKAGE_SHOW_URL=https://data.spatialhub.scot/api/3/action/package_show?id=local_authority_boundaries-is
BOUNDARY_GEOJSON_URL=
BOUNDARY_AUTHKEY=

ROS_DOWNLOAD_BASE_URL=https://ros-inspire.themapcloud.com/maps/download/ros-cp.cadastralparcel
ROS_VIEW_SERVICE_URL=https://ros-inspire.themapcloud.com/maps/wms?service=WMS&request=GetCapabilities&version=1.3.0
ROS_API_BASE_URL=https://api.scotlis.ros.gov.uk
ROS_CLIENT_ID=
ROS_CLIENT_SECRET=

SUPABASE_AUDIT_BUCKET_NAME=landintel-ingest-audit
TEMP_STORAGE_PATH=/app/.tmp
LOG_LEVEL=INFO
LOG_JSON=true
LOG_FILE_PATH=/app/logs/landintel_ingest.log
BATCH_SIZE=1000
HTTP_TIMEOUT_SECONDS=120
BOUNDARY_SIMPLIFY_TOLERANCE=10

ENABLE_INTERNAL_SCHEDULER=false
QUARTERLY_CRON=0 6 2 3,6,9,12 *
